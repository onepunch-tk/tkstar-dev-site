{
  "name": "tkstar-dev",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "react-router build",
    "dev": "react-router dev",
    "preview": "react-router build && vite preview",
    "deploy": "react-router build && wrangler deploy",
    "typecheck": "wrangler types && react-router typegen && tsc -b",
    "lint": "biome lint .",
